<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <!-- Matches the installed .NET 10 SDK. Drop to net8.0-windows if you install the .NET 8 packs. -->
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>AgentCake</AssemblyName>
    <RootNamespace>AgentCake</RootNamespace>
    <!-- High-DPI crispness for the dynamically rendered tray glyph. -->
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <Version>0.1.0</Version>
    <Product>AgentCake</Product>
    <!-- System.Text.Json ships in the shared framework, so no NuGet restore is needed. -->
  </PropertyGroup>

  <!-- For a single-file publish, see the README (uses dotnet publish with PublishSingleFile). -->

</Project>
